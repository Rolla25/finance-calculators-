.tabs{display:flex;border-bottom:1px solid #e0e0e0;margin-bottom:.75rem;overflow-x:auto;gap:0}
.tab-btn{padding:7px 13px;font-size:12px;color:#666;background:transparent;border:none;cursor:pointer;font-family:sans-serif;border-bottom:2px solid transparent;margin-bottom:-1px;white-space:nowrap}
