.infl-note{background:#f8f8f8;border:1px solid #e0e0e0;border-radius:6px;padding:8px 12px;font-size:11px;color:#555;margin-top:6px;display:none}
.infl-note strong{color:#1a1a1a}
.zero-hint{font-size:10px;color:#999;margin-top:2px}
</style>

<div class="wrap">
