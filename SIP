    </div>
  </div>
  <div class="g2">
    <div class="field"><label>Time horizon (years)</label><input type="number" id="g-yr" min="0" max="50" step="1" value="15" oninput="calc()"></div>
    <div class="field"><label>Additional months</label><input type="number" id="g-mo" min="0" max="11" step="1" value="0" oninput="calc()"></div>
  </div>

  <div class="section-box">
