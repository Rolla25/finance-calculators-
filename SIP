.chart-wrap{position:relative;width:100%;height:230px;margin-top:.5rem;background:#ffffff;border-radius:8px;border:1px solid #e8e8e8;padding:4px}
.reset-btn{background:#ffffff;border:1px solid #d0d0d0;border-radius:6px;padding:7px 14px;font-size:12px;color:#555;cursor:pointer;font-family:sans-serif;display:flex;align-items:center;gap:5px;margin-top:1rem}
