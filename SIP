<div id="impact-banner" class="banner green"></div>
<div id="results" style="margin-top:1.25rem"></div>
<button class="reset-btn" onclick="resetCalc()">↺ Reset calculator</button>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
let mode='fv', c1=null, c2=null;

function switchMode(m){
  mode=m;
  document.getElementById('panel-fv').style.display=m==='fv'?'':'none';
  document.getElementById('panel-goal').style.display=m==='goal'?'':'none';
  document.getElementById('btn-fv').classList.toggle('active',m==='fv');
  document.getElementById('btn-goal').classList.toggle('active',m==='goal');
  calc();
}
function gv(id){return parseFloat(document.getElementById(id).value)||0;}
function fmtINR(n){
  if(isNaN(n)||!isFinite(n)||n===null)return '—';
  const neg=n<0;n=Math.abs(Math.round(n));
  let s;
  if(n>=10000000)s='₹'+(n/10000000).toFixed(2).replace(/\.?0+$/,'')+'Cr';
  else if(n>=100000)s='₹'+(n/100000).toFixed(2).replace(/\.?0+$/,'')+'L';
  else s='₹'+n.toLocaleString('en-IN');
  return neg?'-'+s:s;
}
function fmtFull(n){
  if(isNaN(n)||!isFinite(n)||n===null)return '—';
  return '₹'+Math.round(n).toLocaleString('en-IN');
}

// Simulate SIP month-by-month using the given annualRate.
// Used for both nominal return and real return (inflation-adjusted) calculations.
// annualRate: nominal or real annual return %
// stepupPct:  annual step-up % (0 = fixed SIP)
// lump:       one-time lumpsum invested at t=0, compounds at same annualRate
function simulate(sip,annualRate,totalMonths,stepupPct,lump){
  const r=annualRate/100/12; // monthly rate derived from annual nominal (or real) return
  let fvSip=0,invested=0,curSip=sip,lumpFV=lump||0;
  const rows=[];
  for(let m=1;m<=totalMonths;m++){
    if(m>1&&(m-1)%12===0&&stepupPct>0) curSip*=(1+stepupPct/100);
    fvSip=fvSip*(1+r)+curSip*(1+r);
    invested+=curSip;
    lumpFV*=(1+r);
    if(m%12===0||m===totalMonths){
      const yr=Math.ceil(m/12);
      const totalFV=fvSip+lumpFV;
      rows.push({yr,sipAmt:Math.round(curSip),invested:Math.round(invested),sipFV:Math.round(fvSip),lumpFV:Math.round(lumpFV),totalFV:Math.round(totalFV),gains:Math.round(totalFV-(invested+(lump||0)))});
    }
  }
  return rows;
}

// Fisher equation: Real Return = ((1 + Nominal) / (1 + Inflation)) - 1
// This gives the true purchasing-power growth rate, stripping out inflation.
// When inflation = 0, realRate = nominalRate (no adjustment needed).
// When inflation = nominal return, realRate ≈ 0% (corpus preserves purchasing power only).
// We re-run simulate() with realRate to get inflation-adjusted corpus directly,
// rather than discounting the final corpus — which would wrongly treat all SIP
// contributions as if they were invested on day one.
function realRate(nominalPct, inflationPct){
  if(inflationPct<=0) return nominalPct; // no inflation → real = nominal
  return (((1+nominalPct/100)/(1+inflationPct/100))-1)*100;
}

function solveStartSIP(corpus,rate,months,stepupPct){
  if(stepupPct<=0){
    const r=rate/100/12;
    return corpus*r/((Math.pow(1+r,months)-1)*(1+r));
  }
  let lo=1,hi=corpus;
  for(let i=0;i<80;i++){
    const mid=(lo+hi)/2;
    const rows=simulate(mid,rate,months,stepupPct,0);
    if(rows[rows.length-1].sipFV<corpus)lo=mid; else hi=mid;
  }
  return (lo+hi)/2;
}

function activeTab(id){
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.getElementById('tb-'+id).classList.add('active');
  document.getElementById('tp-'+id).classList.add('active');
}
function dCharts(){if(c1){c1.destroy();c1=null;}if(c2){c2.destroy();c2=null;}}
const whiteBg={id:'whiteBg',beforeDraw(chart){const ctx=chart.canvas.getContext('2d');ctx.save();ctx.fillStyle='#ffffff';ctx.fillRect(0,0,chart.width,chart.height);ctx.restore();}};
function mkBar(id,labels,datasets){
  const ctx=document.getElementById(id);if(!ctx)return null;
  const dk=window.matchMedia('(prefers-color-scheme:dark)').matches;
  return new Chart(ctx,{type:'bar',data:{labels,datasets},plugins:[whiteBg],options:{responsive:true,maintainAspectRatio:false,animation:{duration:200},plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>' '+fmtFull(c.raw)}},backgroundColor:'#ffffff'},scales:{x:{grid:{display:false},ticks:{color:'#666',font:{size:10},autoSkip:true,maxRotation:45}},y:{grid:{color:'rgba(0,0,0,.06)'},ticks:{color:'#666',font:{size:10},callback:v=>fmtINR(v)}}}}});
}
function mkLine(id,labels,datasets){
  const ctx=document.getElementById(id);if(!ctx)return null;
  const dk=window.matchMedia('(prefers-color-scheme:dark)').matches;
  return new Chart(ctx,{type:'line',data:{labels,datasets},plugins:[whiteBg],options:{responsive:true,maintainAspectRatio:false,animation:{duration:200},plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>' '+fmtFull(c.raw)}},backgroundColor:'#ffffff'},scales:{x:{grid:{display:false},ticks:{color:'#666',font:{size:10}}},y:{grid:{color:'rgba(0,0,0,.06)'},ticks:{color:'#666',font:{size:10},callback:v=>fmtINR(v)}}}}});
}

function calc(){if(mode==='fv')calcFV();else calcGoal();}

function calcFV(){
  const sip=gv('fv-sip'),rate=gv('fv-rate'),yr=gv('fv-yr'),mo=gv('fv-mo');
  const suRate=gv('fv-su-rate');
  const lump=gv('fv-lump');
  const inflRate=gv('fv-infl-rate');
  const suOn=suRate>0, lumpOn=lump>0, inflOn=inflRate>0;

  document.getElementById('fv-sip-err').classList.toggle('show',sip<100);
  document.getElementById('fv-rate-err').classList.toggle('show',rate<0.1||rate>50);
  if(sip<100||rate<0.1||rate>50){document.getElementById('results').innerHTML='';return;}

  const totalMonths=Math.max(1,yr*12+mo);
  const yrs=totalMonths/12;

  // Step-up preview
  const prev=document.getElementById('fv-su-preview');
  if(suOn){
    let p='<span style="font-size:10px;color:var(--color-text-tertiary);font-weight:500">SIP progression:</span>';
    let s=sip;
    for(let y=1;y<=Math.min(4,Math.ceil(yrs));y++){
      if(y>1)s*=(1+suRate/100);
      p+=`<span>Yr ${y}: <strong>${fmtINR(s)}</strong>/mo</span>`;
    }
    if(Math.ceil(yrs)>4)p+=`<span style="color:var(--color-text-tertiary)">… up to ${fmtINR(sip*Math.pow(1+suRate/100,Math.ceil(yrs)-1))}/mo</span>`;
    prev.innerHTML=p;prev.style.display='flex';
  } else {prev.innerHTML='';prev.style.display='none';}

  // Nominal simulation
  const fixedRows=simulate(sip,rate,totalMonths,0,lump);
  const fLast=fixedRows[fixedRows.length-1];

  // Inflation-adjusted: re-run using real return (Fisher equation) instead of discounting final corpus
  const rReal=inflOn?realRate(rate,inflRate):rate;
  const fixedRealRows=inflOn?simulate(sip,rReal,totalMonths,0,lump):null;
  const fixedRealFV=inflOn?fixedRealRows[fixedRealRows.length-1].totalFV:null;

  // Step-up nominal
  let suRows=null,sLast=null,suRealFV=null;
  if(suOn){
    suRows=simulate(sip,rate,totalMonths,suRate,lump);
    sLast=suRows[suRows.length-1];
    // Step-up inflation-adjusted: re-run with real return + step-up
    if(inflOn){
      const suRealRows=simulate(sip,rReal,totalMonths,suRate,lump);
      suRealFV=suRealRows[suRealRows.length-1].totalFV;
    }
  }

  // Banner
  const banner=document.getElementById('impact-banner');
  if(suOn&&sLast&&sLast.totalFV>fLast.totalFV){
    const extra=sLast.totalFV-fLast.totalFV;
    banner.style.display='block';
    banner.innerHTML=`<strong>Step-Up impact:</strong> A ${suRate}% annual step-up creates <strong>${fmtINR(extra)}</strong> extra wealth — <strong>${Math.round(extra/fLast.totalFV*100)}% more</strong> than a flat SIP.`;
  } else banner.style.display='none';

  const dk=window.matchMedia('(prefers-color-scheme:dark)').matches;
  const totalInv=fLast.invested+(lump||0);

  // Cards
  let html=`<div class="sl">Fixed SIP — Results</div>
  <div class="g${inflOn?'4':'3'}" style="margin-bottom:8px">
    <div class="mc hl"><div class="lb">Total portfolio value</div><div class="v">${fmtINR(fLast.totalFV)}</div></div>
    <div class="mc"><div class="lb">Total invested${lumpOn?' (SIP + Lump)':''}</div><div class="v">${fmtINR(totalInv)}</div></div>
    <div class="mc"><div class="lb">Total gains</div><div class="v" style="color:#3b6d11">${fmtINR(fLast.gains)}</div></div>
    ${inflOn?`<div class="mc or"><div class="lb">Value in today's money<br>(${inflRate}% inflation)</div><div class="v">${fmtINR(fixedRealFV)}</div></div>`:''}
  </div>`;

  if(suOn&&sLast){
    const suTotalInv=sLast.invested+(lump||0);
    html+=`<div class="sl" style="margin-top:.85rem">Step-Up SIP ${suRate}% p.a. — Results</div>
    <div class="g${inflOn?'4':'3'}" style="margin-bottom:8px">
      <div class="mc hl"><div class="lb">Total portfolio value</div><div class="v">${fmtINR(sLast.totalFV)}</div></div>
      <div class="mc"><div class="lb">Total invested${lumpOn?' (SIP + Lump)':''}</div><div class="v">${fmtINR(suTotalInv)}</div></div>
      <div class="mc"><div class="lb">Total gains</div><div class="v" style="color:#3b6d11">${fmtINR(sLast.gains)}</div></div>
      ${inflOn?`<div class="mc or"><div class="lb">Value in today's money<br>(${inflRate}% inflation)</div><div class="v">${fmtINR(suRealFV)}</div></div>`:''}
    </div>`;
  }

  if(lumpOn){
    html+=`<div class="sl" style="margin-top:.85rem">Lumpsum breakdown</div>
    <div class="g3" style="margin-bottom:8px">
      <div class="mc bl"><div class="lb">Lumpsum invested</div><div class="v">${fmtINR(lump)}</div></div>
      <div class="mc bl"><div class="lb">Lumpsum future value</div><div class="v">${fmtINR(fLast.lumpFV)}</div></div>
      <div class="mc bl"><div class="lb">Lumpsum gains</div><div class="v">${fmtINR(fLast.lumpFV-lump)}</div></div>
    </div>`;
  }

  html+=`<div style="font-size:11px;color:var(--color-text-tertiary);margin:.4rem 0 .8rem">Return: ${rate}% p.a. &nbsp;·&nbsp; ${yr}y ${mo}m &nbsp;·&nbsp; Monthly compounding${suOn?' &nbsp;·&nbsp; Step-up: '+suRate+'%/yr':''}${inflOn?' &nbsp;·&nbsp; Inflation: '+inflRate+'%':''}</div>`;

  // Tabs
  html+=`<div class="tabs">
    <button class="tab-btn active" id="tb-chart" onclick="activeTab('chart')">Growth chart</button>
    ${suOn?'<button class="tab-btn" id="tb-comp" onclick="activeTab(\'comp\')">Fixed vs Step-up</button>':''}
    <button class="tab-btn" id="tb-break" onclick="activeTab('break')">Year-wise breakdown</button>
    <button class="tab-btn" id="tb-sched" onclick="activeTab('sched')">SIP schedule</button>
  </div>`;

  // Chart tab
  html+=`<div class="tab-panel active" id="tp-chart">
    <div class="leg">
      <span><span class="lsq" style="background:${dk?'#639922':'#c0dd97'}"></span>Invested</span>
      <span><span class="lsq" style="background:#3b6d11"></span>Fixed SIP portfolio</span>
      ${suOn?`<span><span class="lsq" style="background:#185fa5"></span>Step-up portfolio</span>`:''}
    </div>
    <div class="chart-wrap"><canvas id="c1"></canvas></div>
  </div>`;

  // Comp tab
  if(suOn){
    html+=`<div class="tab-panel" id="tp-comp">
      <div class="leg">
        <span><span class="lsq" style="background:#85b7eb"></span>Fixed SIP</span>
        <span><span class="lsq" style="background:#3b6d11"></span>Step-up SIP</span>
        ${inflOn?`<span><span class="lsq" style="background:#c47000;opacity:.7"></span>Fixed (real)</span><span><span class="lsq" style="background:#e8a030;opacity:.7"></span>Step-up (real)</span>`:''}
      </div>
      <div class="chart-wrap"><canvas id="c2"></canvas></div>
      <div class="tw" style="margin-top:.5rem">
        <table class="bk"><thead><tr><th>Year</th><th>Fixed SIP</th><th>Step-up SIP</th><th>Extra wealth</th>${inflOn?'<th>Fixed (real)</th><th>Step-up (real)</th>':''}</tr></thead><tbody>
        ${fixedRows.map((r,i)=>{
          const sr=suRows[i],diff=sr.totalFV-r.totalFV;
          const fR=inflOn&&fixedRealRows?fixedRealRows[i].totalFV:null;
          const sR=inflOn?(()=>{const rr=simulate(sip,rReal,totalMonths,suRate,lump);return rr[i]?rr[i].totalFV:null})():null;
          return `<tr><td>${r.yr}</td><td>${fmtFull(r.totalFV)}</td><td>${fmtFull(sr.totalFV)}</td><td style="color:#3b6d11">${fmtFull(diff)}</td>${inflOn?`<td style="color:#9a5000">${fmtFull(fR)}</td><td style="color:#9a5000">${fmtFull(sR)}</td>`:''}</tr>`;
        }).join('')}
        </tbody></table>
      </div>
    </div>`;
  }

  // Breakdown tab — nominal rows + real-return rows for inflation-adjusted column
  let tBreak=`<table class="bk"><thead><tr><th>Year</th><th>Monthly SIP</th><th>Total invested</th>${lumpOn?'<th>Lumpsum FV</th>':''}<th>SIP corpus</th><th>Portfolio FV</th><th>Gains</th>${inflOn?'<th>Real value (today\'s ₹)</th>':''}</tr></thead><tbody>`;
  fixedRows.forEach((r,i)=>{
    const realRow=inflOn&&fixedRealRows?fixedRealRows[i]:null;
    tBreak+=`<tr><td>${r.yr}</td><td>${fmtFull(r.sipAmt)}</td><td>${fmtFull(r.invested+(lump||0))}</td>${lumpOn?`<td>${fmtFull(r.lumpFV)}</td>`:''}<td>${fmtFull(r.sipFV)}</td><td>${fmtFull(r.totalFV)}</td><td style="color:#3b6d11">${fmtFull(r.gains)}</td>${inflOn?`<td style="color:#9a5000">${realRow?fmtFull(realRow.totalFV):'—'}</td>`:''}</tr>`;
  });
  tBreak+='</tbody></table>';

  // Schedule tab
  let tSched=`<table class="bk"><thead><tr><th>Year</th><th>Fixed SIP/mo</th><th>Annual (fixed)</th>${suOn?'<th>Step-up SIP/mo</th><th>Annual (step-up)</th>':''}</tr></thead><tbody>`;
  fixedRows.forEach((r,i)=>{
    tSched+=`<tr><td>${r.yr}</td><td>${fmtFull(r.sipAmt)}</td><td>${fmtFull(r.sipAmt*12)}</td>${suOn?`<td style="color:#3b6d11">${fmtFull(suRows[i].sipAmt)}</td><td style="color:#3b6d11">${fmtFull(suRows[i].sipAmt*12)}</td>`:''}</tr>`;
  });
  tSched+='</tbody></table>';

  html+=`<div class="tab-panel" id="tp-break"><div class="tw">${tBreak}</div></div>
  <div class="tab-panel" id="tp-sched"><div class="tw">${tSched}</div></div>`;

  document.getElementById('results').innerHTML=html;
  dCharts();
  const labels=fixedRows.map(r=>'Y'+r.yr);
  requestAnimationFrame(()=>{
    const ds=[
      {label:'Invested',data:fixedRows.map(r=>r.invested+(lump||0)),backgroundColor:dk?'#639922':'#c0dd97',borderRadius:3},
      {label:'Fixed SIP',data:fixedRows.map(r=>r.totalFV),backgroundColor:'#3b6d11',borderRadius:3}
    ];
    if(suOn)ds.push({label:'Step-up',data:suRows.map(r=>r.totalFV),backgroundColor:'#185fa5',borderRadius:3});
    c1=mkBar('c1',labels,ds);
    if(suOn){
      const ld=[
        {label:'Fixed',data:fixedRows.map(r=>r.totalFV),borderColor:'#85b7eb',backgroundColor:'rgba(133,183,235,.1)',fill:true,tension:.4,pointRadius:2},
        {label:'Step-up',data:suRows.map(r=>r.totalFV),borderColor:'#3b6d11',backgroundColor:'rgba(59,109,17,.1)',fill:true,tension:.4,pointRadius:2}
      ];
      if(inflOn){
        ld.push({label:'Fixed real',data:fixedRows.map(r=>Math.round(r.totalFV/Math.pow(1+inflRate/100,r.yr))),borderColor:'#c47000',backgroundColor:'transparent',fill:false,tension:.4,pointRadius:2,borderDash:[4,3]});
        ld.push({label:'Step-up real',data:suRows.map(r=>Math.round(r.totalFV/Math.pow(1+inflRate/100,r.yr))),borderColor:'#e8a030',backgroundColor:'transparent',fill:false,tension:.4,pointRadius:2,borderDash:[4,3]});
      }
      c2=mkLine('c2',labels,ld);
    }
  });
}

function calcGoal(){
  const corpus=gv('g-corpus'),rate=gv('g-rate'),yr=gv('g-yr'),mo=gv('g-mo');
  const suRate=gv('g-su-rate');
  const inflRate=gv('g-infl-rate');
  const suOn=suRate>0, inflOn=inflRate>0;

  document.getElementById('g-corpus-err').classList.toggle('show',corpus<10000);
  document.getElementById('g-rate-err').classList.toggle('show',rate<0.1||rate>50);
  if(corpus<10000||rate<0.1||rate>50){document.getElementById('results').innerHTML='';return;}

  const totalMonths=Math.max(1,yr*12+mo);
  const yrs=totalMonths/12;
  const adjCorpus=inflOn?corpus*Math.pow(1+inflRate/100,yrs):corpus;

  // Inflation note
  const note=document.getElementById('g-infl-note');
  if(inflOn){
    note.style.display='block';
    note.innerHTML=`Your goal of <strong>${fmtFull(corpus)}</strong> today will require <strong>${fmtFull(adjCorpus)}</strong> after ${yr}y ${mo}m at ${inflRate}% inflation. The SIP below targets this inflation-adjusted amount.`;
  } else note.style.display='none';

  // Step-up preview
  const prev=document.getElementById('g-su-preview');
  if(suOn){
    const startSip=solveStartSIP(adjCorpus,rate,totalMonths,suRate);
    let p='<span style="font-size:10px;color:var(--color-text-tertiary);font-weight:500">Starting SIP steps up to:</span>';
    let s=startSip;
    for(let y=1;y<=Math.min(3,Math.ceil(yrs));y++){
      if(y>1)s*=(1+suRate/100);
      p+=`<span>Yr ${y}: <strong>${fmtINR(s)}</strong>/mo</span>`;
    }
    prev.innerHTML=p;prev.style.display='flex';
  } else {prev.innerHTML='';prev.style.display='none';}

  // Fixed SIP
  const mRate=rate/100/12;
  const fixedSip=adjCorpus*mRate/((Math.pow(1+mRate,totalMonths)-1)*(1+mRate));
  const fixedRows=simulate(fixedSip,rate,totalMonths,0,0);
  const fLast=fixedRows[fixedRows.length-1];

  // Step-up SIP
  let suSip=null,suRows=null,sLast=null;
  if(suOn){
    suSip=solveStartSIP(adjCorpus,rate,totalMonths,suRate);
    suRows=simulate(suSip,rate,totalMonths,suRate,0);
    sLast=suRows[suRows.length-1];
  }

  // Banner
  const banner=document.getElementById('impact-banner');
  if(suOn&&suSip){
    const saving=fixedSip-suSip;
    banner.style.display='block';
    banner.innerHTML=`<strong>Step-Up impact:</strong> A ${suRate}% annual step-up reduces your <em>starting</em> SIP by <strong>${fmtINR(saving)}/month</strong> — from ${fmtINR(fixedSip)} to ${fmtINR(suSip)} (${Math.round(saving/fixedSip*100)}% lower to start).`;
  } else banner.style.display='none';

  const dk=window.matchMedia('(prefers-color-scheme:dark)').matches;

  let html=`<div class="sl">Fixed SIP Required</div>
  <div class="g3" style="margin-bottom:8px">
    <div class="mc hl"><div class="lb">Monthly SIP needed</div><div class="v">${fmtINR(fixedSip)}</div></div>
    <div class="mc"><div class="lb">Total you'll invest</div><div class="v">${fmtINR(fLast.invested)}</div></div>
    <div class="mc"><div class="lb">Wealth from returns</div><div class="v" style="color:#3b6d11">${fmtINR(fLast.gains)}</div></div>
  </div>`;

  if(suOn&&suSip&&sLast){
    html+=`<div class="sl" style="margin-top:.85rem">Step-Up SIP Required (${suRate}% p.a.)</div>
    <div class="g4" style="margin-bottom:8px">
      <div class="mc hl"><div class="lb">Starting monthly SIP</div><div class="v">${fmtINR(suSip)}</div></div>
      <div class="mc bl"><div class="lb">SIP in final year</div><div class="v">${fmtINR(sLast.sipAmt)}</div></div>
      <div class="mc"><div class="lb">Total you'll invest</div><div class="v">${fmtINR(sLast.invested)}</div></div>
      <div class="mc"><div class="lb">Wealth from returns</div><div class="v" style="color:#3b6d11">${fmtINR(sLast.gains)}</div></div>
    </div>`;
  }

  if(inflOn){
    html+=`<div class="sl" style="margin-top:.85rem">Inflation impact</div>
    <div class="g3" style="margin-bottom:8px">
      <div class="mc"><div class="lb">Your goal (today's value)</div><div class="v">${fmtINR(corpus)}</div></div>
      <div class="mc or"><div class="lb">Required corpus in ${yr}y<br>(after ${inflRate}% inflation)</div><div class="v">${fmtINR(adjCorpus)}</div></div>
      <div class="mc or"><div class="lb">Purchasing power loss</div><div class="v">${fmtINR(adjCorpus-corpus)}</div></div>
    </div>`;
  }

  html+=`<div style="font-size:11px;color:var(--color-text-tertiary);margin:.4rem 0 .8rem">Goal: ${fmtFull(inflOn?adjCorpus:corpus)} &nbsp;·&nbsp; Return: ${rate}% p.a. &nbsp;·&nbsp; ${yr}y ${mo}m${suOn?' &nbsp;·&nbsp; Step-up: '+suRate+'%/yr':''}${inflOn?' &nbsp;·&nbsp; Inflation: '+inflRate+'%':''}</div>`;

  html+=`<div class="tabs">
    <button class="tab-btn active" id="tb-chart" onclick="activeTab('chart')">Goal chart</button>
    ${suOn?'<button class="tab-btn" id="tb-comp" onclick="activeTab(\'comp\')">Fixed vs Step-up</button>':''}
    <button class="tab-btn" id="tb-break" onclick="activeTab('break')">Year-wise breakdown</button>
    ${suOn?'<button class="tab-btn" id="tb-sched" onclick="activeTab(\'sched\')">SIP schedule</button>':''}
  </div>`;

  html+=`<div class="tab-panel active" id="tp-chart">
    <div class="leg">
      <span><span class="lsq" style="background:${dk?'#639922':'#c0dd97'}"></span>Invested</span>
      <span><span class="lsq" style="background:#3b6d11"></span>Fixed SIP portfolio</span>
      ${suOn?`<span><span class="lsq" style="background:#185fa5"></span>Step-up portfolio</span>`:''}
    </div>
    <div class="chart-wrap"><canvas id="c1"></canvas></div>
  </div>`;

  if(suOn&&suRows){
    html+=`<div class="tab-panel" id="tp-comp">
      <div class="leg">
        <span><span class="lsq" style="background:#85b7eb"></span>Fixed SIP (${fmtINR(fixedSip)}/mo)</span>
        <span><span class="lsq" style="background:#3b6d11"></span>Step-up (starts ${fmtINR(suSip)}/mo)</span>
      </div>
      <div class="chart-wrap"><canvas id="c2"></canvas></div>
      <div class="tw" style="margin-top:.5rem">
        <table class="bk"><thead><tr><th>Year</th><th>Fixed SIP</th><th>Step-up SIP</th><th>Goal %</th></tr></thead><tbody>
        ${fixedRows.map((r,i)=>{
          const sr=suRows[i];
          return `<tr><td>${r.yr}</td><td>${fmtFull(r.sipFV)}</td><td style="color:#3b6d11">${fmtFull(sr.sipFV)}</td><td style="color:#3b6d11">${Math.min(100,Math.round(sr.sipFV/adjCorpus*100))}%</td></tr>`;
        }).join('')}
        </tbody></table>
      </div>
    </div>
    <div class="tab-panel" id="tp-sched">
      <div class="tw">
        <table class="bk"><thead><tr><th>Year</th><th>Fixed SIP/mo</th><th>Step-up SIP/mo</th><th>Annual (step-up)</th></tr></thead><tbody>
        ${fixedRows.map((r,i)=>`<tr><td>${r.yr}</td><td>${fmtFull(r.sipAmt)}</td><td style="color:#3b6d11">${fmtFull(suRows[i].sipAmt)}</td><td style="color:#3b6d11">${fmtFull(suRows[i].sipAmt*12)}</td></tr>`).join('')}
        </tbody></table>
      </div>
    </div>`;
  }

  let tBreak=`<table class="bk"><thead><tr><th>Year</th><th>Monthly SIP</th><th>Invested</th><th>Portfolio FV</th><th>Gains</th><th>Goal %</th></tr></thead><tbody>`;
  fixedRows.forEach(r=>{
    tBreak+=`<tr><td>${r.yr}</td><td>${fmtFull(r.sipAmt)}</td><td>${fmtFull(r.invested)}</td><td>${fmtFull(r.sipFV)}</td><td style="color:#3b6d11">${fmtFull(r.gains)}</td><td style="color:#3b6d11">${Math.min(100,Math.round(r.sipFV/adjCorpus*100))}%</td></tr>`;
  });
  tBreak+='</tbody></table>';
  html+=`<div class="tab-panel" id="tp-break"><div class="tw">${tBreak}</div></div>`;

  document.getElementById('results').innerHTML=html;
  dCharts();
  const labels=fixedRows.map(r=>'Y'+r.yr);
  requestAnimationFrame(()=>{
    const ds=[
      {label:'Invested',data:fixedRows.map(r=>r.invested),backgroundColor:dk?'#639922':'#c0dd97',borderRadius:3},
      {label:'Fixed',data:fixedRows.map(r=>r.sipFV),backgroundColor:'#3b6d11',borderRadius:3}
    ];
    if(suOn)ds.push({label:'Step-up',data:suRows.map(r=>r.sipFV),backgroundColor:'#185fa5',borderRadius:3});
    c1=mkBar('c1',labels,ds);
    if(suOn)c2=mkLine('c2',labels,[
      {label:'Fixed SIP',data:fixedRows.map(r=>r.sipFV),borderColor:'#85b7eb',backgroundColor:'rgba(133,183,235,.1)',fill:true,tension:.4,pointRadius:2},
      {label:'Step-up SIP',data:suRows.map(r=>r.sipFV),borderColor:'#3b6d11',backgroundColor:'rgba(59,109,17,.1)',fill:true,tension:.4,pointRadius:2}
    ]);
  });
}

function resetCalc(){
  const d={'fv-sip':10000,'fv-rate':12,'fv-yr':15,'fv-mo':0,'fv-su-rate':0,'fv-lump':0,'fv-infl-rate':0,'g-corpus':10000000,'g-rate':12,'g-yr':15,'g-mo':0,'g-su-rate':0,'g-infl-rate':0};
  Object.entries(d).forEach(([id,v])=>{const el=document.getElementById(id);if(el)el.value=v;});
  document.getElementById('impact-banner').style.display='none';
  const n=document.getElementById('g-infl-note');if(n)n.style.display='none';
  ['fv-su-preview','g-su-preview'].forEach(id=>{const el=document.getElementById(id);if(el){el.innerHTML='';el.style.display='none';}});
  calc();
}
calc();
</script>
