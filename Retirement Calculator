import { useState, useMemo } from "react";

// ── formatters ──────────────────────────────────────────────────────────────
const fl = (n) => Math.floor(n);
const fmt = (n) => "₹" + fl(n).toLocaleString("en-IN");
const fmtCr = (n) => {
  const abs = Math.abs(n), sign = n < 0 ? "-" : "";
  return abs >= 1e7
    ? sign + "₹" + (fl(abs / 1e5) / 100).toFixed(2) + " Cr"
    : sign + "₹" + (fl((abs / 1e5) * 100) / 100).toFixed(2) + " L";
};

